<?xml version="1.0"?>
<clickhouse>
    <profiles>
        <default>
            <!-- Per-query memory limit (safe for 2 GB container) -->
            <max_memory_usage>1073741824</max_memory_usage>   <!-- 1 GB -->
            <max_execution_time>30</max_execution_time>
            <max_threads>2</max_threads>

            <!-- Spill to disk instead of OOM on large aggregations -->
            <max_bytes_before_external_group_by>536870912</max_bytes_before_external_group_by>  <!-- 512 MB -->
            <max_bytes_before_external_sort>536870912</max_bytes_before_external_sort>          <!-- 512 MB -->

            <!-- Safety: cap result size to prevent accidental huge fetches -->
            <max_result_rows>100000</max_result_rows>
            <result_overflow_mode>break</result_overflow_mode>

            <!-- Log workload: no benefit from uncompressed cache -->
            <use_uncompressed_cache>0</use_uncompressed_cache>

            <!-- Small dimension tables → hash join -->
            <join_use_nulls>1</join_use_nulls>

            <!-- Async inserts: batch incoming log writes server-side -->
            <async_insert>1</async_insert>
            <wait_for_async_insert>0</wait_for_async_insert>
            <async_insert_max_data_size>10485760</async_insert_max_data_size>  <!-- 10 MB flush threshold -->
            <async_insert_busy_timeout_ms>1000</async_insert_busy_timeout_ms>  <!-- 1 s flush interval -->

            <!-- Prefer reading from projections when beneficial -->
            <optimize_read_in_order>1</optimize_read_in_order>

            <!-- COUNT() optimization: use metadata when no WHERE -->
            <optimize_trivial_count_query>1</optimize_trivial_count_query>

            <!-- Skip-index aware: prune granules using secondary indices -->
            <force_data_skipping_indices/>  <!-- empty = use when available -->
        </default>
    </profiles>
</clickhouse>
