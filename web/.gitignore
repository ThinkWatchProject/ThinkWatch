# Logs (root-level only — `logs` without a slash would otherwise
# match any nested directory called `logs`, including the
# `routes/logs/` source folder).
/logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Playwright local artefacts — regenerated on every run.
playwright-report
test-results

