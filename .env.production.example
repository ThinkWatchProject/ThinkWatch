# AgentBastion Production Environment
# Copy to .env.production and fill in ALL values before deploying.
# Generate secrets: openssl rand -hex 32

# --- Required (static, env-only) ---
DATABASE_URL=postgres://bastion:CHANGE_ME@postgres:5432/agent_bastion
REDIS_URL=redis://redis:6379
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32       # Min 32 chars
ENCRYPTION_KEY=CHANGE_ME_USE_openssl_rand_hex_32   # Exactly 64 hex chars
SERVER_HOST=0.0.0.0
GATEWAY_PORT=3000
CONSOLE_PORT=3001
CORS_ORIGINS=https://console.yourdomain.com
RUST_LOG=info,agent_bastion=info

# ClickHouse (audit log storage & search)
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DB=agent_bastion
CLICKHOUSE_USER=bastion
CLICKHOUSE_PASSWORD=CHANGE_ME

# OIDC / SSO
OIDC_ISSUER_URL=https://auth.yourdomain.com
OIDC_CLIENT_ID=CHANGE_ME
OIDC_CLIENT_SECRET=CHANGE_ME
OIDC_REDIRECT_URL=https://console.yourdomain.com/api/auth/sso/callback

# Docker Compose specific
DB_USER=bastion
DB_PASSWORD=CHANGE_ME
DB_NAME=agent_bastion

# --- Dynamic Settings (configured via Web UI after first run) ---
# On first start, visit the console to complete the setup wizard.
# After setup, the following are managed through Admin > Settings:
#   - JWT access/refresh token TTLs
#   - Response cache TTL
#   - Content filter & PII redactor patterns
#   - Budget alert thresholds & webhook URL
#   - API key policies (default expiry, rotation, inactivity timeout)
#   - Data retention policies (usage records, audit logs)
#   - Signature verification parameters
# Log forwarding is configured via Admin > Log Forwarding.
