# ThinkWatch Production Environment
# Copy to .env.production and fill in ALL values before deploying.
# Generate secrets: openssl rand -hex 32

# --- Required (static, env-only) ---
DATABASE_URL=postgres://thinkwatch:CHANGE_ME@postgres:5432/think_watch
DB_MAX_CONNECTIONS=10
REDIS_URL=redis://redis:6379
JWT_SECRET=CHANGE_ME_USE_openssl_rand_hex_32       # Min 32 chars
ENCRYPTION_KEY=CHANGE_ME_USE_openssl_rand_hex_32   # Exactly 64 hex chars
SERVER_HOST=0.0.0.0
GATEWAY_PORT=3000
CONSOLE_PORT=3001
CORS_ORIGINS=https://console.yourdomain.com
RUST_LOG=info,think_watch=info

# ClickHouse (audit log storage & search)
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DB=think_watch
CLICKHOUSE_USER=thinkwatch
CLICKHOUSE_PASSWORD=CHANGE_ME

# Bearer token required to scrape /metrics on the public gateway
# port. `deploy/generate-secrets.sh` populates this automatically;
# only set it by hand if you're hand-rolling .env.production.
# When this is unset the /metrics route is NOT mounted at all
# (returns 404) — the safe default, since the endpoint leaks cost
# / token-usage / error-rate signals. Configure your Prometheus
# scrape job with a matching `bearer_token` (or
# `Authorization: Bearer <value>` header).
METRICS_BEARER_TOKEN=CHANGE_ME_USE_openssl_rand_hex_32

# Docker Compose specific
DB_USER=thinkwatch
DB_PASSWORD=CHANGE_ME
DB_NAME=think_watch
