# === ThinkWatch Environment ===
# Copy to .env and fill in values. Use `deploy/generate-secrets.sh` to generate.

# --- PostgreSQL ---
DB_USER=thinkwatch
DB_PASSWORD=              # openssl rand -hex 16
DB_NAME=think_watch
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}

# --- Redis ---
REDIS_PASSWORD=           # openssl rand -hex 16
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# --- Application ---
JWT_SECRET=               # REQUIRED: openssl rand -hex 32
ENCRYPTION_KEY=           # REQUIRED: openssl rand -hex 32 (exactly 64 hex chars)
SERVER_HOST=0.0.0.0
GATEWAY_PORT=3000
CONSOLE_PORT=3001
CORS_ORIGINS=http://localhost:5173
RUST_LOG=info,think_watch=debug

# --- ClickHouse (audit log storage & search) ---
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=think_watch
CLICKHOUSE_USER=thinkwatch
CLICKHOUSE_PASSWORD=      # openssl rand -hex 16

# --- Zitadel (dev OIDC provider) ---
ZITADEL_PG_PASSWORD=      # openssl rand -hex 16
ZITADEL_MASTERKEY=        # openssl rand -hex 16 (exactly 32 hex chars)

# --- Optional ---
# Bearer token for scraping /metrics. When this is unset, the
# /metrics route is NOT mounted at all (returns 404) — the safe
# default, since the endpoint leaks cost / token / error signals.
# Set to a random string (`openssl rand -hex 32`) to enable
# Prometheus scraping; the scraper must then pass the same value
# as `Authorization: Bearer <value>`.
# METRICS_BEARER_TOKEN=

# --- Dynamic Settings ---
# Everything below is managed through Admin > Settings in the web
# console — do NOT put them in env. The list:
#   JWT access/refresh TTLs, cache TTL, content filters, PII
#   patterns, budget alerts, API key lifecycle policies, data
#   retention, signature parameters, rate-limit fail-closed,
#   per-model token weighting, and SSO/OIDC config (issuer URL,
#   client id, encrypted client secret, redirect URL).
# Log forwarding (Syslog, Kafka, Webhook) → Admin > Log Forwarding.
