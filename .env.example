# === AgentBastion Environment ===
# Copy to .env and fill in values. Use `deploy/generate-secrets.sh` to generate.

# --- PostgreSQL ---
DB_USER=bastion
DB_PASSWORD=              # openssl rand -hex 16
DB_NAME=agent_bastion
DATABASE_URL=postgres://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}

# --- Redis ---
REDIS_PASSWORD=           # openssl rand -hex 16
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379

# --- Application ---
JWT_SECRET=               # REQUIRED: openssl rand -hex 32
ENCRYPTION_KEY=           # REQUIRED: openssl rand -hex 32 (exactly 64 hex chars)
SERVER_HOST=0.0.0.0
GATEWAY_PORT=3000
CONSOLE_PORT=3001
CORS_ORIGINS=http://localhost:5173
RUST_LOG=info,agent_bastion=debug

# --- ClickHouse (audit log storage & search) ---
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=agent_bastion
CLICKHOUSE_USER=bastion
CLICKHOUSE_PASSWORD=      # openssl rand -hex 16

# --- Zitadel (dev OIDC provider) ---
ZITADEL_PG_PASSWORD=      # openssl rand -hex 16
ZITADEL_MASTERKEY=        # openssl rand -hex 16 (exactly 32 hex chars)

# OIDC / SSO — configure via Admin > Settings in the web console
# These env vars are only used as initial seed on first startup.
# OIDC_ISSUER_URL=http://localhost:8080
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URL=http://localhost:3001/api/auth/sso/callback

# --- Dynamic Settings ---
# The following are managed through Admin > Settings in the web console:
#   JWT TTLs, cache TTL, content filters, PII patterns, budget alerts,
#   API key policies, data retention, signature parameters, SSO/OIDC config.
# Log forwarding (Syslog, Kafka, Webhook) → Admin > Log Forwarding.
