DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_bastion
REDIS_URL=redis://:devredispass@localhost:6379
JWT_SECRET=           # REQUIRED: min 32 chars, openssl rand -hex 32
ENCRYPTION_KEY=       # REQUIRED: exactly 64 hex chars, openssl rand -hex 32
SERVER_HOST=0.0.0.0
GATEWAY_PORT=3000
CONSOLE_PORT=3001
CORS_ORIGINS=http://localhost:5173
RUST_LOG=info,agent_bastion=debug

# ClickHouse (audit log storage & search)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=agent_bastion
CLICKHOUSE_USER=bastion
CLICKHOUSE_PASSWORD=bastion_dev

# OIDC / SSO (Zitadel dev instance)
OIDC_ISSUER_URL=http://localhost:8080
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:3001/api/auth/sso/callback

# --- Dynamic Settings (configured via Web UI after first run) ---
# The following are now managed through Admin > Settings in the console:
#   - JWT access/refresh token TTLs
#   - Response cache TTL
#   - Content filter patterns
#   - PII redactor patterns
#   - Budget alert thresholds & webhook URL
#   - API key policies (default expiry, rotation, inactivity timeout)
#   - Data retention policies
#   - Signature verification parameters
# Log forwarding (Syslog, Kafka, Webhook) is configured via Admin > Log Forwarding
