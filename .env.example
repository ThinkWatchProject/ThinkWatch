DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_bastion
REDIS_URL=redis://:devredispass@localhost:6379
JWT_SECRET=           # REQUIRED: openssl rand -hex 32
ENCRYPTION_KEY=       # REQUIRED: openssl rand -hex 32
SERVER_HOST=0.0.0.0
GATEWAY_PORT=3000
CONSOLE_PORT=3001
CORS_ORIGINS=http://localhost:5173
RUST_LOG=info,agent_bastion=debug

# Quickwit (audit log search engine)
QUICKWIT_URL=http://localhost:7280
QUICKWIT_INDEX=audit_logs

# Log forwarding (Syslog, Kafka, Webhook) is now configured via the Web UI
# Navigate to Admin > Log Forwarding in the console

# OIDC / SSO (Zitadel dev instance)
OIDC_ISSUER_URL=http://localhost:8080
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=http://localhost:3001/api/auth/sso/callback
